{
  "manifest_version": 3,
  "name": "GoidaX",
  "version": "1.0.0",
  "description": "Разблокировка сайтов через DNS и прокси. Современный интерфейс для обхода блокировок в РФ.",
  "permissions": [
    "proxy",
    "storage",
    "alarms",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}