{
  "manifest_version": 3,
  "name": "GoidaX",
  "version": "1.0.0",
  "description": "Разблокировка сайтов: YouTube, TikTok, AI и другие. Современный обход блокировок.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["proxy", "storage", "notifications", "alarms"],
  "host_permissions": ["<all_urls>"]
}